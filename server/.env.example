# Set USE_DB=true to use a real MongoDB instance (requires MONGODB_URI)
# Default: false (uses in-memory MongoDB — data lost on restart)
USE_DB=false

PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/spliteasy
JWT_SECRET=your-super-secret-jwt-key-change-this

# OpenRouter (https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=sk-or-...
# Model: openrouter/auto (default, auto-selects best), or any model from https://openrouter.ai/models
LLM_MODEL=openrouter/auto

NODE_ENV=development
